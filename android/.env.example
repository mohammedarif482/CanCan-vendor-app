# 🔧 NOOB-FRIENDLY ENVIRONMENT SETUP
# Copy this file to .env and fill in your details

# ===========================================
# STEP 1: SUPABASE SETUP (REQUIRED)
# ===========================================

# 1. Go to https://supabase.com
# 2. Create FREE account
# 3. Create new project
# 4. Go to Project Settings > API
# 5. Copy your Project URL and anon key below

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Example format:
# SUPABASE_URL=https://abcdefghijk.lmno.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# STEP 2: APP CONFIGURATION
# ===========================================

# Development mode (set to false for production)
DEV_MODE=true

# Debug mode (shows detailed logs)
DEBUG_MODE=true

# Environment type
ENV=development

# ===========================================
# STEP 3: OPTIONAL FEATURES
# ===========================================

# Enable push notifications (requires Firebase setup)
ENABLE_PUSH_NOTIFICATIONS=false

# Enable analytics tracking
ENABLE_ANALYTICS=true

# Enable crash reporting
ENABLE_CRASH_REPORTING=false

# ===========================================
# STEP 4: OPTIONAL SERVICES
# ===========================================

# Uncomment these ONLY if you want to use these services:

# Firebase Cloud Messaging (for push notifications)
# FCM_SERVER_KEY=your_fcm_server_key

# Payment Gateway (Razorpay)
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Maps (for location services)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# WhatsApp Business API
# WHATSAPP_API_KEY=your_whatsapp_api_key
# WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# ===========================================
# STEP 5: SAVE AND RUN
# ===========================================

# After filling this file:
# 1. Save it as ".env" (in the same folder as this file)
# 2. Run: flutter pub get
# 3. Run: flutter run
# 4. App should start! 🎉