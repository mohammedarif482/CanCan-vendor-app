# =============================================================================
# Can Can frontend — copy to `.env` or `.env.local` and fill values.
# Only variable NAMES matter for the app; comments are optional.
# =============================================================================

# --- Supabase (required for API routes + any client Supabase usage) ----------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Portal login: env super-admin (optional if you use admin_users in DB) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use-a-strong-password

# --- JWT signing for portal sessions (recommended in production) -------------
JWT_SECRET=change-me-to-a-long-random-string

# --- Optional dev bypass: admin@cancan.com / admin123 ------------------------
# DEV_MODE=true

# --- Optional vendor dev auth -------------------------------------------------
# DEV_PHONE=

# --- Optional WhatsApp --------------------------------------------------------
# NEXT_PUBLIC_WHATSAPP_NUMBER=
# WHATSAPP_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_WEBHOOK_SECRET=
# META_APP_SECRET=

# --- Cron jobs (Vercel automatically sends this as Authorization: Bearer <value>
# to any /api/* route hit by a vercel.json cron entry) --------------------------
# CRON_SECRET=

# --- Push notifications (FCM) -------------------------------------------------
# Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Paste the ENTIRE JSON file content as a single-line string.
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"cancan-16d78",...}

# --- Reverse geocoding (Google Maps Geocoding API) ----------------------------
# console.cloud.google.com → APIs & Services → Credentials → enable "Geocoding API"
# GOOGLE_MAPS_GEOCODING_API_KEY=

# --- Payouts (Cashfree Payouts) ------------------------------------------------
# merchant.cashfree.com → Developers → API Keys (use the Payouts client id/secret,
# NOT the Payment Gateway ones — they are separate products/credentials)
# CASHFREE_PAYOUTS_CLIENT_ID=
# CASHFREE_PAYOUTS_CLIENT_SECRET=
# CASHFREE_PAYOUTS_ENV=TEST
# PAYOUT_PROVIDER_DEFAULT=cashfree
# ENABLE_REAL_PAYOUTS=false

# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL is optional if you set SUPABASE_URL (server reads both).
# Use SUPABASE_ANON_KEY (not NEXT_PUBLIC_) so the anon key is not embedded in
# client JS. This app’s API routes use the service role; browser bundle does
# not need the anon key.
# =============================================================================
